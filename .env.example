# Required for booking enquiry notifications.
RESEND_API_KEY=
ADMIN_EMAIL=anselmpius@gmail.com

# Use a verified domain sender in production, for example:
# RESEND_FROM_EMAIL="Anselm Long Bookings <bookings@anselmlong.com>"
# The default code fallback is Resend's onboarding sender for account/testing delivery.
RESEND_FROM_EMAIL=

# Public site origin used to build the editable quote link inside notifications.
NEXT_PUBLIC_URL=https://photos.anselmlong.com

# Optional fallback if email delivery fails and the Telegram bot is configured.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
